rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2024-05-24 21:20
    // Objetivo: Garantir leitura pública recursiva para resolver erros de permissão em listagens.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Conteúdo público dos conjuntos (Notícias, Vídeos, Playlists, Calendário)
    // Usando {id=**} para garantir que listagens na raiz da coleção funcionem sem erros.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    
    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para outros caminhos
    match /{document=**} {
      allow read, write: if false;
    }
  }
}