rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2025-05-25 16:15 (Correção de Permissão de Listagem Pública)
    // Objetivo: Resolver definitivamente erros de 'Missing or insufficient permissions' em consultas públicas.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Permite leitura pública para as coleções de conteúdo (visitantes e logados)
    // Usamos regras explícitas para a coleção e caminhos recursivos para garantir cobertura total.
    
    match /community-news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /community-news/{allPaths=**} {
      allow read: if true;
    }
    
    match /community-playlist/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /community-playlist/{allPaths=**} {
      allow read: if true;
    }

    match /community-videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /community-videos/{allPaths=**} {
      allow read: if true;
    }

    match /calendarEntries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /calendarEntries/{allPaths=**} {
      allow read: if true;
    }

    match /hymns/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /hymns/{allPaths=**} {
      allow read: if true;
    }

    // Regras para hinos de solistas (leitura pública, escrita permitida apenas ao dono)
    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    match /solistaHymns/{allPaths=**} {
      allow read: if true;
    }

    // Perfil de usuário (acesso privado ao próprio usuário)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança de coleções não mapeadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}