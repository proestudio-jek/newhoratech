rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC
    // Gatilho de Implantação: 2025-05-26 02:15 (GMT)
    // Objetivo: Resolver erros de 'list' (Missing or insufficient permissions) para visitantes.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções com LEITURA PÚBLICA (Permite 'get' e 'list' para todos)
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Hinos de solistas: Leitura pública, escrita apenas para o autor logado.
    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: Acesso restrito ao próprio dono.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança de coleções não especificadas.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}