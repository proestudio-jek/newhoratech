rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2024-05-24 20:50
    // Objetivo: Resolver erro de permissão (Missing or insufficient permissions) para visitantes.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Permitir leitura pública (get e list) para todas as coleções de conteúdo dos conjuntos
    // e escrita apenas para usuários autenticados.

    match /community-news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    
    match /hymns/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança máxima em outros caminhos
    match /{document=**} {
      allow read, write: if false;
    }
  }
}