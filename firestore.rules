rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC (VERSÃO ESTÁVEL)
    // Gatilho de Implantação: 2025-05-27 19:30 (GMT)
    // Objetivo: Garantir leitura pública total e escrita protegida.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções de Conteúdo Público: Leitura (get/list) liberada para todos.
    // Escrita protegida por autenticação.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: O próprio dono pode ler e escrever.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}