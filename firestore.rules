rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // FORÇAR IMPLANTAÇÃO: Atualizado em 24/05/2024 às 19:20 para resolver erro de permissão pública persistente.
    // Esta regra garante que as coleções de conteúdo dos conjuntos sejam visíveis para todos.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções de Conteúdo Público (Leitura aberta, Escrita apenas para usuários logados)
    
    match /community-news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    
    match /hymns/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Perfis de usuários (Privado: Apenas o dono acessa)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para qualquer outra tentativa
    match /{document=**} {
      allow read, write: if false;
    }
  }
}