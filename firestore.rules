rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Qualquer pessoa pode ler notícias, playlists, vídeos e hinos.
    match /community-news/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // Apenas usuários logados (admins) podem escrever
    }
    
    match /community-playlist/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // Apenas usuários logados (admins) podem escrever
    }

    match /community-videos/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // Apenas usuários logados (admins) podem escrever
    }

    // Regras para a coleção de usuários
    match /users/{userId} {
      // Permite que um novo usuário seja criado se o ID do documento
      // for o mesmo ID do usuário que está se cadastrando.
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Permite que um usuário leia seus próprios dados.
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Impede a atualização ou exclusão por enquanto.
      allow update, delete: if false;
    }
  }
}