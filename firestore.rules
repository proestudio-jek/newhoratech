rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC (VERSÃO CORRIGIDA)
    // Gatilho de Implantação: 2025-05-26 18:30 (GMT)
    // Objetivo: Permitir leitura e listagem pública para visitantes e usuários logados em coleções comunitárias.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Permite leitura pública total (get e list) para conteúdos da comunidade.
    // O uso de {id=**} garante que consultas de listagem na raiz da coleção sejam permitidas.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Hinos de solistas: Leitura pública, escrita restrita ao autor.
    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: Acesso privado ao próprio dono.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para qualquer outra coleção não especificada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}