
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isCentralAdmin() {
      return isSignedIn() && request.auth.token.email == 'jeffersonnascimentoone@outlook.com';
    }

    function isApprovedSoloist() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc.data.status == 'approved';
    }

    // Conteúdo Público: Leitura irrestrita.
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isCentralAdmin();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isCentralAdmin();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isCentralAdmin();
    }

    match /calendarEvents/{id=**} {
      allow read: if true;
      allow write: if isCentralAdmin();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isCentralAdmin();
    }

    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isApprovedSoloist() || isCentralAdmin();
      allow update, delete: if isCentralAdmin() || (isApprovedSoloist() && resource.data.solistaId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isCentralAdmin());
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
