rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2025-05-25 23:30 (Correção definitiva de permissão de listagem pública)
    // Objetivo: Garantir que visitantes e usuários logados possam ler conteúdos públicos sem restrição.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções de conteúdo público (Leitura para todos, Escrita para usuários logados)
    
    match /community-news/{newsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{playlistId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{entryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{hymnId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Regras para hinos de solistas (Leitura pública, escrita apenas para o dono do documento)
    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }

    // Perfil de usuário (Acesso estritamente privado)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança de coleções não mapeadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}