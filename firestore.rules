
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra auxiliar para verificar se o usuário é o dono do hino
    function isOwner(solistaId) {
      return request.auth != null && request.auth.uid == solistaId;
    }

    // Qualquer pessoa pode ler notícias, playlists e vídeos do conjunto.
    match /community-news/{docId} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
    
    match /community-playlist/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /community-videos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regras para hinos de solistas
    match /solistaHymns/{docId} {
      // Todos podem ver os hinos
      allow read: if true;
      // Usuários logados podem criar novos hinos
      allow create: if request.auth != null;
      // Apenas o dono do hino pode editar ou excluir
      allow update, delete: if isOwner(resource.data.solistaId);
    }

    // Regras para o calendário de hinos
    match /calendarEntries/{docId} {
      // Todos podem ver a programação do calendário
      allow read: if true;
      // Usuários logados podem agendar ou remover hinos do calendário
      allow write: if request.auth != null;
    }

    // Regras para a coleção de usuários
    match /users/{userId} {
      // Permite que um novo usuário seja criado se o ID do documento for o mesmo ID do usuário
      allow create: if request.auth != null && request.auth.uid == userId;
      // Permite que um usuário leia e atualize seus próprios dados
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Impede a exclusão de perfis por enquanto
      allow delete: if false;
    }

    // Regra geral de negação para qualquer outra coleção não especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
