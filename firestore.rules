rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Comentário de gatilho: Garantindo acesso público de leitura para as galerias dos conjuntos.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Conteúdos públicos dos conjuntos (Notícias, Playlists, Vídeos, Calendário)
    // Qualquer pessoa pode ler, mas apenas usuários logados (admins) podem escrever.
    
    match /community-news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Galeria de hinos dos solistas
    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      // Apenas o dono do hino pode editar ou excluir
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    
    // Hinos base do sistema
    match /hymns/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Perfis de usuários
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para qualquer outra coleção não especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}