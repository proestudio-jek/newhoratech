rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2025-05-25 10:15 (Gatilho de Correção de Permissão Pública)
    // Objetivo: Resolver erros de 'Missing or insufficient permissions' em listagens públicas (auth: null).
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções com leitura pública total para visitantes e usuários logados.
    // O padrão {id=**} permite acesso recursivo a documentos e listagens.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Regras para hinos de solistas (leitura pública, escrita permitida apenas ao dono)
    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }

    // Perfil de usuário (acesso privado ao próprio usuário)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança de coleções não mapeadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}