rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC (VERSÃO DEFINITIVA)
    // Gatilho de Implantação: 2025-05-27 15:30 (GMT)
    // Objetivo: Permitir leitura pública irrestrita para evitar erros de permissão 'list'.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Conteúdos Públicos: Acesso de leitura (get/list) liberado para todos.
    // Escrita protegida por autenticação.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: Acesso privado ao próprio dono.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Fallback de segurança
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}