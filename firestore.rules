rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC (VERSÃO FINAL)
    // Gatilho de Implantação: 2025-05-26 16:10 (GMT)
    // Objetivo: Resolver erros de 'list' e 'get' permitindo leitura pública em coleções comunitárias.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções com LEITURA PÚBLICA TOTAL (Permite 'get' e 'list' para todos, inclusive visitantes)
    // O seletor {document=**} garante acesso recursivo para listagens de coleções.
    
    match /community-news/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Hinos de solistas: Leitura pública, escrita restrita ao autor.
    match /solistaHymns/{document=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: Acesso privado ao próprio dono.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}