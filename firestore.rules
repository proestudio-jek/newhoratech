rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2025-05-25 18:45 (Resolução definitiva de erros de listagem pública)
    // Objetivo: Garantir que visitantes (auth == null) possam listar e ler conteúdos públicos.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções de conteúdo público (Leitura para todos, Escrita para usuários logados)
    // O uso de {id=**} garante que permissões de listagem (list) e leitura (get) sejam herdadas recursivamente.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Regras para hinos de solistas (Leitura pública, escrita apenas para o dono do documento)
    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    match /solistaHymns/{allPaths=**} {
      allow read: if true;
    }

    // Perfil de usuário (Acesso estritamente privado)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança de coleções não mapeadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}