rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA ATUALIZADAS - PROMUSIC
    // Forçar implantação: 2025-05-25 15:10 (Gatilho de Correção de Permissão Recursiva)
    // Objetivo: Resolver definitivamente erros de 'Missing or insufficient permissions' em consultas públicas usando caminhos recursivos.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleções com leitura pública permitida para visitantes e usuários logados.
    // O uso de {id=**} garante que operações de 'list' e 'get' funcionem em toda a hierarquia.
    
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Regras para hinos de solistas (leitura pública, escrita permitida apenas ao dono)
    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }

    // Perfil de usuário (acesso privado ao próprio usuário)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança de coleções não mapeadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}