
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Permite leitura pública para conteúdos dos conjuntos
    // Permite escrita para qualquer usuário autenticado (gerenciada via UI isAdmin)
    
    match /community-news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      // Apenas o dono do hino pode editar ou excluir
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    
    // Entidades baseadas no backend.json
    match /hymns/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /images/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Perfis de usuários
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueia qualquer outro acesso por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
