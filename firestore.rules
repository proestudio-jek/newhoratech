rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Forçar implantação: Atualizado em 24/05/2024 às 17:45 para resolver erro de permissão pública.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Regras para coleções de conteúdo público (Leitura para todos, Escrita para usuários logados)
    
    match /community-news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.solistaId;
    }
    
    match /hymns/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Perfis de usuários (Apenas o próprio dono acessa)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para segurança
    match /{document=**} {
      allow read, write: if false;
    }
  }
}