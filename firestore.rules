
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC (VERSÃO ATUALIZADA COM APROVAÇÕES)
    // Gatilho de Implantação: 2025-05-27 20:45 (GMT)
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isApprovedSoloist() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc.data.status == 'approved';
    }

    // Conteúdo Público: Leitura irrestrita. Escrita restrita.
    match /community-news/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isApprovedSoloist();
      allow update, delete: if isApprovedSoloist() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: O dono pode ler/escrever. Status só pode ser alterado via backend/admin se necessário, 
    // mas aqui permitimos que o dono crie o perfil inicial.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.uid == userId ||
        // Permitir que admins aprovem (embora usemos o console ou modo admin local)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'role'])
      );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
