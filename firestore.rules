rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRAS DE SEGURANÇA - PROMUSIC (VERSÃO ATUALIZADA)
    // Gatilho de Implantação: 2025-05-26 21:15 (GMT)
    // Objetivo: Corrigir erros de permissão 'list' em coleções comunitárias para visitantes.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Conteúdos Comunitários: Leitura (get/list) pública irrestrita.
    // Escrita (create/update/delete) exige estar logado.
    
    match /community-news/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community-playlist/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /community-videos/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /calendarEntries/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /hymns/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Hinos de solistas: Leitura pública, escrita restrita ao autor logado.
    match /solistaHymns/{id=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.solistaId == request.auth.uid
      );
    }

    // Perfil de usuário: Acesso privado ao próprio dono.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Bloqueio padrão para qualquer outra coleção não mapeada explicitamente.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}