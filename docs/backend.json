
{
  "entities": {
    "Hymn": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Hymn",
      "type": "object",
      "description": "Represents a hymn with its associated details.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "lyrics": {
          "type": "string"
        },
        "tune": {
          "type": "string"
        },
        "audioUrl": {
          "type": "string",
          "format": "uri"
        },
        "videoUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "title",
        "lyrics"
      ]
    },
    "SolistaHymn": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SolistaHymn",
      "type": "object",
      "description": "Hino postado por um solista específico.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "lyrics": {
          "type": "string"
        },
        "solistaId": {
          "type": "string"
        },
        "solistaName": {
          "type": "string"
        },
        "conjunto": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["title", "solistaId", "solistaName"]
    },
    "CalendarEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CalendarEntry",
      "type": "object",
      "description": "Represents a calendar entry associated with a hymn and a conjunto.",
      "properties": {
        "id": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "hymnId": {
          "type": "string"
        },
        "hymnTitle": {
          "type": "string"
        },
        "conjunto": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "date",
        "hymnTitle",
        "conjunto"
      ]
    },
    "NewsArticle": {
      "title": "NewsArticle",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "conjunto": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "CommunityVideo": {
      "title": "CommunityVideo",
      "type": "object",
      "properties": {
        "youtubeId": { "type": "string" },
        "title": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PlaylistItem": {
      "title": "PlaylistItem",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "conjunto": { "type": "string" }
      },
      "required": [
        "id",
        "email"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/hymns/{hymnId}",
        "definition": {
          "entityName": "Hymn",
          "schema": { "$ref": "#/backend/entities/Hymn" },
          "description": "Stores hymn details."
        }
      },
      {
        "path": "/solistaHymns/{hymnId}",
        "definition": {
          "entityName": "SolistaHymn",
          "schema": { "$ref": "#/backend/entities/SolistaHymn" },
          "description": "Hinos de solistas individuais."
        }
      },
      {
        "path": "/calendarEntries/{calendarEntryId}",
        "definition": {
          "entityName": "CalendarEntry",
          "schema": { "$ref": "#/backend/entities/CalendarEntry" },
          "description": "Associates a hymn with a specific date and conjunto."
        }
      },
      {
        "path": "/community-news/{newsId}",
        "definition": {
          "entityName": "NewsArticle",
          "schema": { "$ref": "#/backend/entities/NewsArticle" },
          "description": "Notícias específicas de cada conjunto."
        }
      },
      {
        "path": "/community-videos/{videoId}",
        "definition": {
          "entityName": "CommunityVideo",
          "schema": { "$ref": "#/backend/entities/CommunityVideo" },
          "description": "Vídeos da galeria de cada conjunto."
        }
      },
      {
        "path": "/community-playlist/{playlistId}",
        "definition": {
          "entityName": "PlaylistItem",
          "schema": { "$ref": "#/backend/entities/PlaylistItem" },
          "description": "Itens de playlist de cada conjunto."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile data."
        }
      }
    ]
  }
}
