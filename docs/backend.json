
{
  "entities": {
    "Hymn": {
      "title": "Hymn",
      "type": "object",
      "description": "Representa um hino no sistema.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "musicUrl": { "type": "string", "format": "uri" }
      },
      "required": ["title"]
    },
    "SolistaHymn": {
      "title": "SolistaHymn",
      "type": "object",
      "description": "Hino postado por um solista específico.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "lyrics": { "type": "string" },
        "solistaId": { "type": "string" },
        "solistaName": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "solistaId", "solistaName", "conjunto"]
    },
    "CalendarEntry": {
      "title": "CalendarEntry",
      "type": "object",
      "description": "Entrada de calendário vinculando um hino a uma data e conjunto.",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "hymnId": { "type": "string" },
        "hymnTitle": { "type": "string" },
        "musicUrl": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "hymnTitle", "conjunto"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "type": "object",
      "description": "Título do evento ou culto em uma data específica.",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "title"]
    },
    "NewsArticle": {
      "title": "NewsArticle",
      "type": "object",
      "description": "Notícia ou aviso de um conjunto.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "conjunto": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "conjunto"]
    },
    "CommunityVideo": {
      "title": "CommunityVideo",
      "type": "object",
      "description": "Vídeo da galeria de um conjunto.",
      "properties": {
        "id": { "type": "string" },
        "youtubeId": { "type": "string" },
        "title": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["youtubeId", "title", "conjunto"]
    },
    "PlaylistItem": {
      "title": "PlaylistItem",
      "type": "object",
      "description": "Item de hino na playlist de um conjunto.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "conjunto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "conjunto"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Perfil de usuário.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "conjunto": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/hymns/{hymnId}": { "schema": { "$ref": "#/backend/entities/Hymn" }, "description": "Hinos base." },
    "/solistaHymns/{hymnId}": { "schema": { "$ref": "#/backend/entities/SolistaHymn" }, "description": "Hinos de solistas." },
    "/calendarEntries/{entryId}": { "schema": { "$ref": "#/backend/entities/CalendarEntry" }, "description": "Entradas do calendário." },
    "/calendarEvents/{eventId}": { "schema": { "$ref": "#/backend/entities/CalendarEvent" }, "description": "Eventos de data no calendário." },
    "/community-news/{newsId}": { "schema": { "$ref": "#/backend/entities/NewsArticle" }, "description": "Notícias dos conjuntos." },
    "/community-videos/{videoId}": { "schema": { "$ref": "#/backend/entities/CommunityVideo" }, "description": "Vídeos dos conjuntos." },
    "/community-playlist/{playlistId}": { "schema": { "$ref": "#/backend/entities/PlaylistItem" }, "description": "Playlists dos conjuntos." },
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Perfis de usuários." }
  }
}
