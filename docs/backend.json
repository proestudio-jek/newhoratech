
{
  "entities": {
    "Hymn": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Hymn",
      "type": "object",
      "description": "Represents a hymn with its associated details.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Hymn entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the hymn."
        },
        "author": {
          "type": "string",
          "description": "The author of the hymn."
        },
        "lyrics": {
          "type": "string",
          "description": "The lyrics of the hymn."
        },
        "tune": {
          "type": "string",
          "description": "The tune or melody associated with the hymn."
        },
        "audioUrl": {
          "type": "string",
          "description": "URL of the audio file for the hymn.",
          "format": "uri"
        },
        "videoUrl": {
          "type": "string",
          "description": "URL of the video associated with the hymn.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "title",
        "lyrics"
      ]
    },
    "SolistaHymn": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SolistaHymn",
      "type": "object",
      "description": "Hino postado por um solista específico.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "lyrics": {
          "type": "string"
        },
        "solistaId": {
          "type": "string"
        },
        "solistaName": {
          "type": "string"
        },
        "conjunto": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["title", "solistaId", "solistaName"]
    },
    "CalendarEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CalendarEntry",
      "type": "object",
      "description": "Represents a calendar entry that associates a hymn with a specific date.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the CalendarEntry entity."
        },
        "date": {
          "type": "string",
          "description": "The date for which the hymn is assigned.",
          "format": "date-time"
        },
        "hymnId": {
          "type": "string",
          "description": "Reference to Hymn. (Relationship: CalendarEntry 1:1 Hymn)"
        }
      },
      "required": [
        "id",
        "date",
        "hymnId"
      ]
    },
    "Video": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Video",
      "type": "object",
      "description": "Represents a video in the video gallery.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Video entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the video."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the video."
        },
        "url": {
          "type": "string",
          "description": "The URL of the video.",
          "format": "uri"
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "The URL of the video thumbnail.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "title",
        "url"
      ]
    },
    "Image": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Image",
      "type": "object",
      "description": "Represents an image to be displayed in the image carousel.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Image entity."
        },
        "title": {
          "type": "string",
          "description": "The title or caption for the image."
        },
        "url": {
          "type": "string",
          "description": "The URL of the image.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "url"
      ]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "conjunto": {
          "type": "string",
          "description": "Conjunto ao qual o solista pertence."
        }
      },
      "required": [
        "id",
        "email"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/hymns/{hymnId}",
        "definition": {
          "entityName": "Hymn",
          "schema": {
            "$ref": "#/backend/entities/Hymn"
          },
          "description": "Stores hymn details.",
          "params": [
            {
              "name": "hymnId",
              "description": "Unique identifier for the hymn."
            }
          ]
        }
      },
      {
        "path": "/solistaHymns/{hymnId}",
        "definition": {
          "entityName": "SolistaHymn",
          "schema": {
            "$ref": "#/backend/entities/SolistaHymn"
          },
          "description": "Hinos de solistas individuais.",
          "params": [
            {
              "name": "hymnId",
              "description": "ID do hino."
            }
          ]
        }
      },
      {
        "path": "/calendarEntries/{calendarEntryId}",
        "definition": {
          "entityName": "CalendarEntry",
          "schema": {
            "$ref": "#/backend/entities/CalendarEntry"
          },
          "description": "Associates a hymn with a specific date.",
          "params": [
            {
              "name": "calendarEntryId",
              "description": "Unique identifier for the calendar entry."
            }
          ]
        }
      },
      {
        "path": "/videos/{videoId}",
        "definition": {
          "entityName": "Video",
          "schema": {
            "$ref": "#/backend/entities/Video"
          },
          "description": "Stores video details for the video gallery.",
          "params": [
            {
              "name": "videoId",
              "description": "Unique identifier for the video."
            }
          ]
        }
      },
      {
        "path": "/images/{imageId}",
        "definition": {
          "entityName": "Image",
          "schema": {
            "$ref": "#/backend/entities/Image"
          },
          "description": "Stores image details for the image carousel.",
          "params": [
            {
              "name": "imageId",
              "description": "Unique identifier for the image."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profile data.",
          "params": [
            {
              "name": "userId",
              "description": "Unique identifier for the user (Firebase UID)."
            }
          ]
        }
      }
    ]
  }
}
